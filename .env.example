# Copy this file to .env and edit values as needed.

# App environment
NEMORAX_ENV=development
LOG_LEVEL=INFO

# Frontend/runtime API target
# Canonical variable for the frontend and local launchers.
# Production example: https://api.nemorax.example.com
NEMORAX_API_URL=http://127.0.0.1:8000

# Backend server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS
# In local development, `*` is acceptable.
# In production, set exact frontend origin(s), comma-separated.
# Example: https://nemorax.vercel.app,https://app.nemorax.example.com
CORS_ORIGINS=*

# Legacy migration input paths
# These files are only used by the explicit import scripts, not by the production backend runtime.
NEMORAX_DATA_DIR=data
NEMORAX_KB_MARKDOWN_PATH=data/school_info.md
NEMORAX_KB_JSON_PATH=data/school_info.json
NEMORAX_KB_CHUNKS_PATH=kb/chunks.jsonl
NEMORAX_KB_SOURCE=supabase

# Supabase-backed persistence and knowledge base
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_TIMEOUT_SECONDS=10

# Neutral LLM settings
# Supported providers: groq, openai_compatible
LLM_PROVIDER=groq
LLM_MODEL=openai/gpt-oss-20b
LLM_FALLBACK_MODEL=llama-3.1-8b-instant
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your-llm-api-key

# Optional provider tuning
LLM_TEMPERATURE=0.25
LLM_TOP_P=1.0
LLM_MAX_COMPLETION_TOKENS=900
LLM_REASONING_EFFORT=medium
LLM_INCLUDE_REASONING=false
LLM_STREAM=true
LLM_SEED=7
LLM_MAX_CONTEXT_TOKENS=16384
LLM_MESSAGE_WINDOW=10
LLM_PROMPT_KNOWLEDGE_CHARS=6000
REQUEST_TIMEOUT_SECONDS=180
HEALTH_TIMEOUT_SECONDS=4
