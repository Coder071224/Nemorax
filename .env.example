# Copy this file to .env and edit values as needed.

# App environment
NEMORAX_ENV=development
LOG_LEVEL=INFO

# Backend server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://127.0.0.1:8000

# CORS
# In production, replace * with the exact frontend origin(s), comma-separated.
CORS_ORIGINS=*

# Data and knowledge-base paths
NEMORAX_DATA_DIR=data
NEMORAX_KB_MARKDOWN_PATH=data/school_info.md
NEMORAX_KB_JSON_PATH=data/school_info.json
NEMORAX_KB_CHUNKS_PATH=kb/chunks.jsonl
NEMORAX_CHROMA_PATH=.chroma_db

# Neutral LLM settings
# Supported providers: groq, openai_compatible
LLM_PROVIDER=groq
LLM_MODEL=openai/gpt-oss-20b
LLM_FALLBACK_MODEL=llama-3.1-8b-instant
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=

# Optional provider tuning
LLM_TEMPERATURE=0.25
LLM_TOP_P=1.0
LLM_MAX_COMPLETION_TOKENS=900
LLM_REASONING_EFFORT=medium
LLM_INCLUDE_REASONING=false
LLM_STREAM=true
LLM_SEED=7
LLM_MAX_CONTEXT_TOKENS=16384
LLM_MESSAGE_WINDOW=10
LLM_PROMPT_KNOWLEDGE_CHARS=6000
REQUEST_TIMEOUT_SECONDS=180
HEALTH_TIMEOUT_SECONDS=4

# Optional Groq shortcuts if LLM_PROVIDER=groq
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-20b
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=
